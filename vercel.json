{
  "projectId": "indoormedia-pwa",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "functions": {
    "api/**/*.js": {
      "memory": 512,
      "maxDuration": 60
    }
  },
  "env": {
    "GOOGLE_PLACES_API_KEY": "@google_places_api_key"
  }
}
